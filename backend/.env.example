# AgroClaim Backend Environment Variables
# Copy this file to .env and fill in your values.

# Database (MongoDB Atlas recommended)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/agroclaim?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Frontend / CORS (origin for API and Socket.io)
CLIENT_URL=http://localhost:3000

# Public base URL for backend (used for AI image URLs and links)
BASE_URL=http://localhost:5000

# Server
PORT=5000
NODE_ENV=development

# Groq AI (optional – fallback analysis used if unset)
# https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
